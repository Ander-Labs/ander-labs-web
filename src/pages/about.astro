---
import Layout from '../layouts/Layout.astro';
const title = 'About — Ander-Labs';
const description = 'About Anderson Ruiz: full stack developer, autodidact, admin→dev, building AISaGrowth for dental clinics in LATAM.';
---

<img src="/images/profile.jpg" alt="Anderson Ruiz" class="profile-photo" />

<Layout title={title} description={description} lang="en">
  <main class="page">
    <div class="about">
      <h1>About</h1>
      <p class="subtitle">
        Autodidact. Operator. Building real products in LATAM.
      </p>

      <div class="bio">
        <p>
          I am <strong>Anderson Ruiz</strong>, a full stack developer based in <strong>Perú</strong> with more than 5 years of experience. I transitioned from business administration to development — and I do not bring beginner energy to code, I bring a view of the business side most engineers never learn.
        </p>
        <p>
          I build <strong>AI-native products</strong> for real businesses, with clear unit economics, no vendor lock-in, and brutal honesty about what works and what does not. My current focus is <strong>AISaGrowth</strong>: market discovery and automation for private dental clinics in LATAM.
        </p>
        <p>
          I also write, automate, and tinker. This site, the internal wiki, the Hermes post factory, and the Astro build itself are products I ship the same way I ship for clients or for my own company: small, concrete, actionable.
        </p>
        <p>
          Tech: <strong>Python, TypeScript, Node, Astro, React, SQL</strong>. Agent systems (Hermes, MCP, A2A). I deliver fast, refactor with evidence, and call bad ideas by their name.
        </p>
      </div>

      <h2>What I am doing now</h2>
      <ul>
        <li><strong>AISaGrowth pilot</strong> — market discovery + agentic automations for private dental clinics in LATAM.</li>
        <li><strong>Ander-Labs Blog</strong> — technical writing on local AI, cost control, and agent systems, in English.</li>
        <li><strong>Internal wiki</strong> — knowledge base for AISaGrowth and Ander-Labs operations.</li>
        <li><strong>Hermes automations</strong> — daily post factory, image review, Telegram notifications.</li>
      </ul>

      <h2>Principles</h2>
      <ul>
        <li>Ship small, concrete actions every day.</li>
        <li>No vendor lock-in — choose tools, not religions.</li>
        <li>Brutal honesty about cost, scope, and quality.</li>
        <li>Autodidact discipline: I learn by building.</li>
      </ul>
    </div>
  </main>
</Layout>

<style>
  .profile-photo {
    width: 140px;
    height: 140px;
    border-radius: 999px;
    object-fit: cover;
    border: 1px solid var(--border);
    margin-bottom: 22px;
    display: block;
  }
  .about h1 { font-size: clamp(30px, 5vw, 56px); margin: 0 0 6px; }
  .about .subtitle { color: var(--muted); margin: 0 0 30px; }
  .bio p { color: #cbd5e1; margin: 0 0 18px; max-width: 760px; }
  .bio p strong { color: var(--fg); }
  .about h2 { font-size: 18px; margin: 32px 0 14px; color: var(--accent); }
  .about ul { padding-left: 22px; color: #cbd5e1; margin: 0 0 18px; max-width: 760px; }
  .about li { margin: 0 0 8px; }
  .about li strong { color: var(--fg); }
</style>
