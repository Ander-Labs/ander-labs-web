---
import Layout from '../../layouts/Layout.astro';
const title = 'Ander-Labs — Portafolio';
const description = 'Desarrollador full stack y constructor AI-native. Ingeniería, agentes locales y negocio real sin vendor lock-in.';
---
<Layout title={title} description={description} lang="es">
  <main>
    <section class="hero">
      <h1>Anderson Ruiz</h1>
      <p class="subtitle">Desarrollador Full Stack · Constructor AI-native · Operador</p>
      <p class="lead">Construyo productos AI-native y herramientas para developers, sin vendor lock-in, con control de costos y orientado a negocios reales.</p>
      <div class="actions">
        <a href="/blog" class="btn primary">Leer el Blog</a>
        <a href="https://ander-labs.blogspot.com" class="btn secondary">Blog en Blogger</a>
      </div>
    </section>
    <section class="blocks">
      <div class="block">
        <h2>Ingeniería</h2>
        <p>Full stack, +5 años, autodidacta. Python, TypeScript, Node, Astro, React, SQL. Entrego rápido y refactorizo con evidencia.</p>
      </div>
      <div class="block">
        <h2>Operador AI-native</h2>
        <p>Construyendo AISaGrowth para clínicas dentales privadas en LATAM. Routing multimodelo, observabilidad local y economía unitaria clara.</p>
      </div>
      <div class="block">
        <h2>Herramientas para devs</h2>
        <p>Hermes Agent, Claude Code loops, MCP y A2A. Diseño sistemas de agentes sin obligar a un solo vendor.</p>
      </div>
    </section>
    <section class="cta">
      <h2>Enfoque actual</h2>
      <p>Market Discovery para clínicas dentales privadas, automatización agentica y escritura técnica prioritaria en inglés.</p>
    </section>
  </main>
</Layout>
