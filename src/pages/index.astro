---
import Layout from '../layouts/Layout.astro';
const title = 'Anderson Ruiz — Full Stack Developer & AI-native builder';
const description = 'Full stack developer with 5+ years of experience and business background. Building AI-native companies, local agents, and developer tools.';
---
<Layout title={title} description={description} lang="en">
  <main>
    <section class="hero">
      <h1>Anderson Ruiz</h1>
      <p class="subtitle">Full Stack Developer · AI-native builder · Operator</p>
      <p class="lead">I build AI-native products and developer tools — without vendor lock-in, with real cost control, and for real businesses.</p>
      <div class="actions">
        <a href="/blog" class="btn primary">Read the Blog</a>
        <a href="https://ander-labs.blogspot.com" class="btn secondary">Blogger Blog</a>
      </div>
    </section>
    <section class="blocks">
      <div class="block">
        <h2>Engineering</h2>
        <p>Full stack, 5+ years, autodidact. Python, TypeScript, Node, Astro, React, SQL. I ship fast and refactor with evidence.</p>
      </div>
      <div class="block">
        <h2>AI-native operator</h2>
        <p>Building AISaGrowth for private dental clinics in LATAM. Multimodel routing, local observability, and clear unit economics.</p>
      </div>
      <div class="block">
        <h2>Developer tools</h2>
        <p>Hermes Agent, Claude Code loops, MCP and A2A. I design agent systems without forcing a single vendor.</p>
      </div>
    </section>
    <section class="cta">
      <h2>Current focus</h2>
      <p>Market Discovery for private dental clinics, agentic automation, and English-first technical writing.</p>
    </section>
  </main>
</Layout>
